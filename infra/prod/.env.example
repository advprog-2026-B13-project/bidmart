# Copy to /opt/bidmart/.env on the production VM and fill in real values.
# NEVER commit the real .env file.

# Note: CHANGE THIS IN GITHUB ACTIONS SECRETS!
CORE_IMAGE=ghcr.io/advprog-2026-b13-project/bidmart-core:main

# Cloud SQL private IP
DATABASE_URL=jdbc:postgresql://CLOUD_SQL_PRIVATE_IP:5432/bidmart
DATABASE_USER=bidmart_user
DATABASE_PASSWORD=

AUTH_JWT_SECRET=
FRONTEND_URL=https://bidmart.store
RESEND_API_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
GRAFANA_PASSWORD=

# Redis VM internal IP
REDIS_HOST=67.67.67.01
