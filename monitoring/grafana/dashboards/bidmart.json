{
  "title": "BidMart — Bidding Performance",
  "uid": "bidmart-bidding",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "APDEX — Place Bid (T=200ms)",
      "description": "Satisfied ≤200ms, Tolerable ≤800ms. Score 1.0 = perfect, <0.7 = poor.",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 1,
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.7  },
              { "color": "green",  "value": 0.94 }
            ]
          },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "scalar(sum(http_server_requests_seconds_bucket{uri=\"/api/bidding/bids\",method=\"POST\",le=\"0.2\"})) / scalar(sum(http_server_requests_seconds_count{uri=\"/api/bidding/bids\",method=\"POST\"}))",
          "legendFormat": "APDEX",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Place Bid — p95 / p50 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 10, "h": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(http_server_requests_seconds_bucket{uri=\"/api/bidding/bids\",method=\"POST\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by(le) (rate(http_server_requests_seconds_bucket{uri=\"/api/bidding/bids\",method=\"POST\"}[5m])))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Bid Throughput (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(outcome) (rate(bidding_place_bid_seconds_count{application=\"bidmart-core\"}[1m]))",
          "legendFormat": "{{ outcome }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Per-Stage Avg Latency",
      "description": "Average time spent in each bidding pipeline stage.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bidding_listing_read_seconds_sum{application=\"bidmart-core\"}[1m]) / rate(bidding_listing_read_seconds_count{application=\"bidmart-core\"}[1m])",
          "legendFormat": "listing_read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bidding_redis_decision_seconds_sum{application=\"bidmart-core\"}[1m]) / rate(bidding_redis_decision_seconds_count{application=\"bidmart-core\"}[1m])",
          "legendFormat": "redis_decision",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bidding_wallet_hold_seconds_sum{application=\"bidmart-core\"}[1m]) / rate(bidding_wallet_hold_seconds_count{application=\"bidmart-core\"}[1m])",
          "legendFormat": "wallet_hold",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bidding_db_write_seconds_sum{application=\"bidmart-core\",outcome=\"leading\"}[1m]) / rate(bidding_db_write_seconds_count{application=\"bidmart-core\",outcome=\"leading\"}[1m])",
          "legendFormat": "db_write",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bidding_place_bid_seconds_sum{application=\"bidmart-core\",outcome=\"leading\"}[1m]) / rate(bidding_place_bid_seconds_count{application=\"bidmart-core\",outcome=\"leading\"}[1m])",
          "legendFormat": "place_bid (total)",
          "refId": "E"
        }
      ]
    },
    {
      "id": 5,
      "title": "HikariCP — Connection Pool",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "acquire_max" },
            "properties": [{ "id": "unit", "value": "s" }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{application=\"bidmart-core\"}",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle{application=\"bidmart-core\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{application=\"bidmart-core\"}",
          "legendFormat": "pending",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_acquire_seconds_max{application=\"bidmart-core\"}",
          "legendFormat": "acquire_max",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "Bid Outcome Counts (total)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "leading" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "error"   }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red"   } }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bidding_place_bid_seconds_count{application=\"bidmart-core\"}",
          "legendFormat": "{{ outcome }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "JVM Memory Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 13, "w": 8, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(area) (jvm_memory_used_bytes{application=\"bidmart-core\"})",
          "legendFormat": "{{ area }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 13, "w": 8, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"bidmart-core\",status=~\"5..\"}[5m])) / sum(rate(http_server_requests_seconds_count{application=\"bidmart-core\"}[5m]))",
          "legendFormat": "5xx rate",
          "refId": "A"
        }
      ]
    }
  ]
}
