							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/profile/deactivate/{{targetUserId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "profile", "deactivate", "{{targetUserId}}"]
						},
						"description": "Deactivate a user account. Requires account:deactivate permission."
					},
					"response": []
				}
			]
		},
