{
	"info": {
		"name": "BidMart API",
		"description": "Postman collection for testing BidMart auction platform APIs. Base URL: http://localhost:8080",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "",
			"type": "string"
		},
		{
			"key": "listingId",
			"value": "",
			"type": "string"
		},
		{
			"key": "orderId",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/health/status",
							"host": ["{{baseUrl}}"],
							"path": ["api", "health", "status"]
						},
						"description": "Check if the service is up and DB is connected"
					},
					"response": []
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Register",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var body = pm.response.json();",
									"    if (body.data && body.data.userId) {",
									"        pm.collectionVariables.set('userId', body.data.userId);",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"secureP@ss123\",\n    \"displayName\": \"Test User\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						},
						"description": "Register a new user account. After registration, login to get tokens."
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var body = pm.response.json();",
									"if (body.data) {",
									"    if (body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
									"    if (body.data.refreshToken) pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
									"    if (body.data.userId) pm.collectionVariables.set('userId', body.data.userId);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@example.com\",\n    \"password\": \"secureP@ss123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						},
						"description": "Login with email and password. Returns accessToken and refreshToken directly if 2FA is disabled, or preAuthToken and mfaType if 2FA is enabled."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var body = pm.response.json();",
									"if (body.data) {",
									"    if (body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
									"    if (body.data.refreshToken) pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
									"    if (body.data.userId) pm.collectionVariables.set('userId', body.data.userId);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "refresh"]
						},
						"description": "Exchange a valid refresh token for a new access token and refresh token pair."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "logout"]
						},
						"description": "Logout current session. Invalidates the current session from Redis cache."
					},
					"response": []
				}
			]
		},
		{
			"name": "MFA",
			"item": [
				{
					"name": "Setup TOTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/setup-totp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "setup-totp"]
						},
						"description": "Initiate TOTP setup. Returns secret and otpAuthUrl. Confirm with /confirm-totp."
					},
					"response": []
				},
				{
					"name": "Confirm TOTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"code\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/confirm-totp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "confirm-totp"]
						},
						"description": "Verify 6-digit TOTP code from authenticator app to activate TOTP 2FA."
					},
					"response": []
				},
				{
					"name": "Enable Email MFA",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/enable-email",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "enable-email"]
						},
						"description": "Enable Email OTP 2FA. On next login, a 6-digit OTP will be sent to the registered email."
					},
					"response": []
				},
				{
					"name": "Request Email OTP",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"preAuthToken\": \"{{preAuthToken}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/request-email-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "request-email-otp"]
						},
						"description": "Send 6-digit OTP to user's email. Requires preAuthToken from login when 2FA is enabled."
					},
					"response": []
				},
				{
					"name": "Verify MFA",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var body = pm.response.json();",
									"if (body.data) {",
									"    if (body.data.accessToken) pm.collectionVariables.set('accessToken', body.data.accessToken);",
									"    if (body.data.refreshToken) pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
									"    if (body.data.userId) pm.collectionVariables.set('userId', body.data.userId);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"preAuthToken\": \"{{preAuthToken}}\",\n    \"code\": \"123456\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/verify",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "verify"]
						},
						"description": "Verify TOTP or Email OTP code to complete login. Returns accessToken and refreshToken."
					},
					"response": []
				},
				{
					"name": "Disable MFA",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/auth/mfa/disable",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "mfa", "disable"]
						},
						"description": "Disable all 2FA on the account."
					},
					"response": []
				}
			]
		},
