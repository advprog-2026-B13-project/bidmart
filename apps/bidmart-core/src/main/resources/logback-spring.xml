<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml" />

    <property name="LOG_DIR" value="${LOG_DIR:-${java.io.tmpdir}/bidmart-logs}" />
    <property name="LOG_FILE_MAX_SIZE" value="${LOG_FILE_MAX_SIZE:-50MB}" />
    <property name="LOG_FILE_TOTAL_CAP" value="${LOG_FILE_TOTAL_CAP:-1GB}" />
    <property name="LOG_FILE_HISTORY" value="${LOG_FILE_HISTORY:-30}" />
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n" />
    <property name="LOG_PATTERN_FILE" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [trace=%X{traceId}] - %msg%n" />
    <property name="LOG_PATTERN_DEV" value="%clr(%d{HH:mm:ss.SSS}){faint} %clr([%thread]){blue} %clr(%-5level) %clr(%logger{36}){cyan} - %msg%n" />

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="bidmart-core" />

    <!-- ======================== CONSOLE APPENDER ======================== -->
    <appender name="CONSOLE_DEV" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN_DEV}</pattern>
        </encoder>
    </appender>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ======================== MAIN FILE APPENDER ======================== -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <encoder>
            <pattern>${LOG_PATTERN_FILE}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <maxHistory>${LOG_FILE_HISTORY}</maxHistory>
            <totalSizeCap>${LOG_FILE_TOTAL_CAP}</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ======================== AUDIT FILE APPENDER ======================== -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-audit.log</file>
        <encoder>
            <pattern>${LOG_PATTERN_FILE}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-audit.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ======================== ERROR FILE APPENDER ======================== -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN_FILE}</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
            <maxHistory>90</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- ======================== ASYNC WRAPPERS ======================== -->
    <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="FILE" />
    </appender>

    <appender name="ASYNC_AUDIT" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="AUDIT_FILE" />
    </appender>

    <appender name="ASYNC_ERROR" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>256</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="ERROR_FILE" />
    </appender>

    <!-- ======================== AUDIT LOGGER ======================== -->
    <logger name="id.ac.ui.cs.advprog.bidmartcore.AUDIT" level="INFO" additivity="true">
        <appender-ref ref="ASYNC_AUDIT" />
    </logger>

    <!-- ======================== REQUEST LOGGER ======================== -->
    <logger name="id.ac.ui.cs.advprog.bidmartcore.infrastructure.adapter.input.rest.RequestLoggingFilter" level="INFO" additivity="true">
    </logger>

    <!-- ======================== QUIET THIRD-PARTY LOGGERS ======================== -->
    <logger name="org.springframework" level="WARN" />
    <logger name="org.hibernate" level="WARN" />
    <logger name="org.hibernate.SQL" level="WARN" />
    <logger name="com.zaxxer.hikari" level="WARN" />
    <logger name="org.apache.catalina" level="WARN" />
    <logger name="org.springframework.security" level="WARN" />
    <logger name="org.springframework.web.servlet" level="WARN" />
    <logger name="io.lettuce" level="WARN" />
    <logger name="redis.clients" level="WARN" />
    <logger name="com.midtrans" level="WARN" />
    <logger name="io.swagger" level="WARN" />
    <logger name="org.springdoc" level="WARN" />
    <logger name="org.flyway" level="WARN" />
    <logger name="io.micrometer" level="WARN" />

    <!-- ======================== SPRING PROFILES ======================== -->
    <springProfile name="dev">
        <logger name="id.ac.ui.cs.advprog.bidmartcore" level="DEBUG" />
        <root level="INFO">
            <appender-ref ref="CONSOLE_DEV" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR" />
        </root>
    </springProfile>

    <springProfile name="prod">
        <logger name="id.ac.ui.cs.advprog.bidmartcore" level="INFO" />
        <root level="WARN">
            <appender-ref ref="CONSOLE_PLAIN" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR" />
        </root>
    </springProfile>

    <springProfile name="!(dev | prod)">
        <logger name="id.ac.ui.cs.advprog.bidmartcore" level="DEBUG" />
        <root level="INFO">
            <appender-ref ref="CONSOLE_DEV" />
            <appender-ref ref="ASYNC_FILE" />
            <appender-ref ref="ASYNC_ERROR" />
        </root>
    </springProfile>

</configuration>
